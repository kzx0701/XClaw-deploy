{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XClaw",
  "version": "1.3.1",
  "identifier": "com.xindieshu.clawdeploy",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "XClaw",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
