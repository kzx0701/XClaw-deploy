{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XClaw",
  "version": "1.0.6",
  "identifier": "com.xindieshu.clawdeploy",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "XClaw",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ5NjQ0NDEwODkwQTU1M0EKUldRNlZRcUpFRVJrU1pObElpbU9SZm5tYXBiYlBkb2JsRlJIdWtCWENkbmQxK3lqZE51Y1hqazcK",
      "endpoints": [
        "https://github.com/kzx0701/XClaw-deploy/releases/latest/download/latest-{{target}}-{{arch}}.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
